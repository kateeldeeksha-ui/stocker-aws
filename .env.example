# Copy this to .env and fill in your values
# Get these from Skill Wallet / Troven Labs AWS credentials page

AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_REGION=us-east-1

# Get these after running: python aws_setup/create_sns.py
USER_ACCOUNT_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:stocker-user-account
TRANSACTION_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:stocker-transactions
